NODE_ENV=development
PORT=3000

# Frontends (CORS)
TENANT_FRONTEND_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3002

# Database
DATABASE_URL="postgresql://neurecore:password@localhost:5432/neurecore_dev?schema=public"

# Vector Database (pgvector - Phase 2)
VECTOR_DATABASE_URL="postgresql://neurecore:password@localhost:5433/neurecore_vectors?schema=public"

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=dev-super-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API Keys (Phase 2 - set when needed)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# MiniMax LLM
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5

# DeepSeek LLM
DEEPSEEK_API_KEY=your-deepseek-api-key

# Xiaomi MiMo LLM
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_MODEL=MiMo-72B-Instruct

# OpenClaw Gateway (AI Agent Communication)
OPENCLAW_ENDPOINT=https://api.openclaw.ai/v1
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_TIMEOUT=30000
OPENCLAW_RETRY_ATTEMPTS=3
OPENCLAW_ENABLE_TRACING=true

# LangSmith Observability
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=neurecore
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING_ENABLED=false

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
