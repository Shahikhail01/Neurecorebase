POSTGRES_PASSWORD=npg_EaF8DrC3hdcm
POSTGRES_DATABASE=neondb

# Database Pool Settings
DATABASE_POOL_SIZE=2
DATABASE_CONNECTION_TIMEOUT=5
DATABASE_STATEMENT_TIMEOUT=10

# ─── Cache (Redis - Upstash) ──────────────────────────────────────────────
REDIS_URL=redis://default:gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg@lasting-gobbler-72608.upstash.io:6379
UPSTASH_REDIS_URL=redis://default:gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg@lasting-gobbler-72608.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://lasting-gobbler-72608.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg

# Cache TTL Settings
CACHE_TTL_DEFAULT=60
CACHE_TTL_SHORT=10
CACHE_TTL_LONG=300

# ─── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET=test-super-secret-change-in-production-min-32-chars-test
JWT_ACCESS_EXPIRES=5m
JWT_REFRESH_EXPIRES=1d
JWT_ALGORITHM=HS256

# ─── Rate Limiting ─────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000
THROTTLE_AUTH_LIMIT=100
THROTTLE_API_LIMIT=1000
THROTTLE_UPLOAD_LIMIT=50

# ─── CORS Configuration ─────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_CREDENTIALS=false
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_HEADERS=Content-Type,Authorization

# ─── Security ────────────────────────────────────────────────────────────────
SESSION_SECRET=test-session-secret-min-32-characters-long
SESSION_COOKIE_NAME=neurecore.test.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE=3600000
CSRF_ENABLED=false
HELMET_ENABLED=false
API_KEY_HEADER=x-api-key
RATE_LIMIT_BY_IP=false

# ─── AI / LLM API Keys (Optional) ──────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4-turbo-preview
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
AI_STREAMING_ENABLED=true
AI_FUNCTION_CALLING_ENABLED=true

# ─── Feature Flags ──────────────────────────────────────────────────────────
FEATURE_ANALYTICS_ENABLED=false
FEATURE_CONNECTORS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=false
FEATURE_VOICE_COMMANDS_ENABLED=false
FEATURE_WORKFLOW_AUTOMATION_ENABLED=false
FEATURE_ADVANCED_REPORTING_ENABLED=false
FEATURE_DEBUG_MODE=true
FEATURE_MAINTENANCE_MODE=false

# ─── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=test
SENTRY_TRACES_SAMPLE_RATE=0.0
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=neurecore-backend-test
LOG_FORMAT=json
LOG_PRETTY_PRINT=false

# ─── File Upload ───────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_FILES_PER_REQUEST=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DIR=./uploads-test
STORAGE_TYPE=local

# ─── Email ────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
EMAIL_FROM_NAME=NeureCore Test

# ─── External Services ─────────────────────────────────────────────────────
WS_ENABLED=false
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000
STORAGE_PROVIDER=local
