# Test environment configuration

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=test
PORT=3000
BACKEND_PORT=3000
API_PREFIX=/api/v1
LOG_LEVEL=error

# ─── Frontend URLs (CORS whitelist) ───────────────────────────────────────
TENANT_FRONTEND_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3002
ADDITIONAL_CORS_ORIGINS=

# ─── Database (PostgreSQL - Neon) ─────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_USER=neondb_owner
