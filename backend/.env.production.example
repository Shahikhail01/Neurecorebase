# Example production environment variables for local testing
# Copy this to .env or use your secret manager. Do NOT commit real secrets.

NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1
VERCEL=true
MODEL_RUNNER_URL=http://localhost:8080
LOG_LEVEL=info
TENANT_FRONTEND_URL=https://tenant.example.com
ADMIN_FRONTEND_URL=https://admin.example.com

# Database (replace with your connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=please_change_me_to_a_secure_value_with_at_least_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Other settings (tweak as needed)
CORS_ORIGINS=*
SESSION_COOKIE_NAME=neurecore.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Feature flags
FEATURE_DEBUG_MODE=false
FEATURE_MAINTENANCE_MODE=false
