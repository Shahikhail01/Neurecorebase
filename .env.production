# ═══════════════════════════════════════════════════════════════════════════
# NeureCore Backend — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to .env on your production server and fill in real values.
# NEVER commit .env to version control.

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BACKEND_PORT=3000
API_PREFIX=/api/v1
LOG_LEVEL=info

# ─── Frontend URLs (CORS whitelist) ───────────────────────────────────────
TENANT_FRONTEND_URL=https://tenant.guvhq.shahisoft.store
ADMIN_FRONTEND_URL=https://admin.guvhq.shahisoft.store
ADDITIONAL_CORS_ORIGINS=

# ─── Database (PostgreSQL - Neon) ─────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech
POSTGRES_PASSWORD=npg_EaF8DrC3hdcm
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:npg_EaF8DrC3hdcm@ep-summer-pond-adpkqy1m-pooler.c-2.us-east-1.aws.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require

# Database Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=10
DATABASE_STATEMENT_TIMEOUT=30

# ─── Cache (Redis - Upstash) ──────────────────────────────────────────────
REDIS_URL=redis://default:gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg@lasting-gobbler-72608.upstash.io:6379
UPSTASH_REDIS_URL=redis://default:gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg@lasting-gobbler-72608.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://lasting-gobbler-72608.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAARugAAIncDEwMDRjMzQ1ZWY3YjU0NGE0YTZmMGRhMDc4MWRjMDc4ZHAxNzI2MDg

# Cache TTL Settings
CACHE_TTL_DEFAULT=3600
CACHE_TTL_SHORT=60
CACHE_TTL_LONG=86400

# ─── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET=dev-super-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_ALGORITHM=HS256
JWT_ISSUER=neurecore
JWT_AUDIENCE=neurecore-api

# ─── Rate Limiting ─────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_API_LIMIT=100
THROTTLE_UPLOAD_LIMIT=5

# ─── CORS Configuration ─────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGINS=
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_HEADERS=Content-Type,Authorization

# ─── Security ────────────────────────────────────────────────────────────────
SESSION_SECRET=
SESSION_COOKIE_NAME=neurecore.sid
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE=86400000
CSRF_ENABLED=true
HELMET_ENABLED=true
API_KEY_HEADER=x-api-key
RATE_LIMIT_BY_IP=true

# ─── AI / LLM API Keys (Optional) ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-4-turbo-preview
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
AI_STREAMING_ENABLED=true
AI_FUNCTION_CALLING_ENABLED=true

# ─── Feature Flags ──────────────────────────────────────────────────────────
FEATURE_ANALYTICS_ENABLED=true
FEATURE_CONNECTORS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_VOICE_COMMANDS_ENABLED=false
FEATURE_WORKFLOW_AUTOMATION_ENABLED=false
FEATURE_ADVANCED_REPORTING_ENABLED=false
FEATURE_DEBUG_MODE=false
FEATURE_MAINTENANCE_MODE=false

# ─── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=neurecore-backend
LOG_FORMAT=json
LOG_PRETTY_PRINT=false

# ─── File Upload ───────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_FILES_PER_REQUEST=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_DIR=./uploads
STORAGE_TYPE=local
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Email ────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
EMAIL_FROM_NAME=NeureCore

# ─── External Services ─────────────────────────────────────────────────────
WS_ENABLED=true
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000
ANALYTICS_WRITE_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=
HUBSPOT_ACCESS_TOKEN=
STORAGE_PROVIDER=local
