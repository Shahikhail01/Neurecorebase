{
  "name": "Universal Continue Config",
  "version": "1.0.0",
  "models": [
    {
      "name": "DeepSeek Local (Ollama)",
      "provider": "ollama",
      "model": "deepseek-coder:6.7b",
      "apiBase": "http://127.0.0.1:11434",
      "contextLength": 8192,
      "completionOptions": {
        "temperature": 0.1,
        "topP": 0.9,
        "maxTokens": 512
      }
    },
    {
      "name": "DeepSeek API",
      "provider": "openai",
      "model": "deepseek-chat",
      "apiBase": "https://api.deepseek.com",
      "apiKey": "${DEEPSEEK_API_KEY}",
      "contextLength": 16384,
      "completionOptions": {
        "temperature": 0.1,
        "topP": 0.9,
        "maxTokens": 1024
      }
    }
  ],
  "tabAutocompleteModel": {
    "name": "DeepSeek Local Autocomplete",
    "provider": "ollama",
    "model": "deepseek-coder:6.7b",
    "apiBase": "http://127.0.0.1:11434",
    "contextLength": 2048
  },
  "tabAutocompleteOptions": {
    "debounceDelay": 250,
    "maxPromptTokens": 1024,
    "multilineCompletions": "auto"
  },
  "systemMessage": "You are an expert software developer. Provide concise, accurate code assistance with clean, maintainable solutions.",
  "contextLength": 16384,
  "allowAnonymousTelemetry": false,
  "autoAccept": true,
  "embeddingsProvider": {
    "provider": "ollama",
    "model": "nomic-embed-text",
    "apiBase": "http://127.0.0.1:11434"
  }
}
