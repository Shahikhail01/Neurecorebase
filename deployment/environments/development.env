# ═══════════════════════════════════════════════════════════════════════════
# Development Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# DO NOT commit this file to version control!
# Copy from development.env.example and fill in your values

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Frontend URLs
TENANT_FRONTEND_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3002

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurecore_dev
DATABASE_POOL_SIZE=5
DATABASE_CONNECTION_TIMEOUT=10
DATABASE_STATEMENT_TIMEOUT=30

# Redis/Cache
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=dev-jwt-secret-min-32-chars-long-enough
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=20
THROTTLE_API_LIMIT=200
THROTTLE_UPLOAD_LIMIT=10

# Security
SESSION_COOKIE_SECURE=false
CSRF_ENABLED=false
HELMET_ENABLED=false

# Feature Flags
FEATURE_ANALYTICS_ENABLED=true
FEATURE_CONNECTORS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_DEBUG_MODE=true

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
OTEL_ENABLED=false
LOG_PRETTY_PRINT=true

# External Services
WS_ENABLED=true
