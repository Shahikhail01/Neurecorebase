# ═══════════════════════════════════════════════════════════════════════════
# Staging Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to staging.env and fill in your values
# DO NOT commit the .env file to version control!

# Application
NODE_ENV=staging
PORT=3000
API_PREFIX=/api/v1
LOG_LEVEL=info
LOG_FORMAT=json

# Frontend URLs
TENANT_FRONTEND_URL=https://tenant-staging.neurecore.com
ADMIN_FRONTEND_URL=https://admin-staging.neurecore.com

# Database (PostgreSQL) - Use Vercel Postgres or Neon
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=10
DATABASE_STATEMENT_TIMEOUT=30

# Redis/Cache - Use Upstash
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT - Use strong secrets from Vercel Project Settings
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=10
THROTTLE_API_LIMIT=100
THROTTLE_UPLOAD_LIMIT=5

# Security
SESSION_COOKIE_SECURE=true
CSRF_ENABLED=true
HELMET_ENABLED=true

# Feature Flags
FEATURE_ANALYTICS_ENABLED=true
FEATURE_CONNECTORS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_DEBUG_MODE=false

# Observability - Configure Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=true

# External Services
WS_ENABLED=true
